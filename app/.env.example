# =============================================================================

# daily_market - environment variables

# =============================================================================

# Copy this file to `secrets/.env` from the project root and fill in real values.

#

# Example:

# daily_market/

# app/

# secrets/

# .env

#

# core.py loads `./secrets/.env` relative to the project root via python-dotenv.

#

# Required vars are checked at startup by `check_required_env` in core.py.

# If a required var is missing, the script exits with a clear message.

#

# Optional vars cause their respective brief sections to be skipped gracefully

# instead of crashing the whole run.

# =============================================================================

# ----- REQUIRED -----

# Telegram bot token from @BotFather.

# Example format:

# <BOT_TOKEN>

TELEGRAM_BOT_TOKEN=

# Numeric Telegram chat ID for admin/default delivery and system alerts.

# To find yours:

# 1. Message your bot.

# 2. Visit:

# https://api.telegram.org/bot<BOT_TOKEN>/getUpdates

# 3. Copy the `chat.id` value.

#

# Group chat IDs may be negative.

TELEGRAM_CHAT_ID=

# ----- OPTIONAL -----

# FRED API key.

# Powers the economic calendar section.

# Signup:

# https://fred.stlouisfed.org/docs/api/api_key.html

#

# If unset, the economic calendar section is skipped.

FRED_API_KEY=

# Financial Modeling Prep API key.

# Powers earnings calendar and per-ticker catalyst data such as analyst grades,

# 8-Ks, and press releases.

#

# Docs:

# https://site.financialmodelingprep.com/developer/docs

#

# If unset, those sections are skipped.

FMP_API_KEY=

# Tradier sandbox token.

# Powers options-positioning data, including put/call ratios, implied volatility,

# greeks, gamma walls, high-open-interest strikes, max pain, and liquidity data.

#

# Sandbox setup:

# 1. Sign up at https://developer.tradier.com/

# 2. Create a Sandbox application.

# 3. Copy the Access Token from the sandbox dashboard.

#

# If unset, Tradier-powered options sections are skipped.

TRADIER_TOKEN=

# Ollama local LLM endpoint.

# Used by generate_briefing.py to turn market_data.md into final_briefing.md.

#

# Defaults assume Ollama is running locally.

# Override OLLAMA_URL if Ollama is bound to a non-default host/port or if you

# proxy it through Tailscale or a reverse proxy.

OLLAMA_URL=http://localhost:11434

# Ollama model name.

# Must match a model you have already pulled.

#

# Example:

# ollama pull llama3.1:8b

OLLAMA_MODEL=llama3.1:8b
